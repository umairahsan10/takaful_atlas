generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Tenancy ───────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  quota            OrgQuota?
  users            User[]
  hospitals        Hospital[]
  parties          Party[]
  categories       Category[]
  claimExtractions ClaimExtraction[]
  ocrUsageLogs     OcrUsageLog[]
  auditLogs        AuditLog[]

  @@map("organizations")
}

enum EnforcementMode {
  HARD_BLOCK
  SOFT_WARN
}

model OrgQuota {
  id                      String          @id @default(cuid())
  orgId                   String          @unique
  maxUsers                Int             @default(5)
  maxExtractionsPerMonth  Int             @default(100)
  bonusExtractions        Int             @default(0)
  enforcementMode         EnforcementMode @default(HARD_BLOCK)
  currentMonthExtractions Int             @default(0)
  quotaResetDay           Int             @default(1)
  lastResetAt             DateTime        @default(now())
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_quotas")
}

// ─── Users & Auth ────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String
  role                Role      @default(STAFF)
  orgId               String?
  isActive            Boolean   @default(true)
  currentSessionToken String?
  createdAt           DateTime  @default(now())
  lastLogin           DateTime?

  org              Organization?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions         Session[]
  claimExtractions ClaimExtraction[]
  ocrUsageLogs     OcrUsageLog[]
  auditLogs        AuditLog[]
  rateCardsCreated RateCard[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Rate Card (Billing Cross-Check) ─────────────────────────────

model Hospital {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rateCards RateCard[]

  @@unique([orgId, name], name: "orgId_name")
  @@index([orgId])
  @@map("hospitals")
}

model Party {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rateCards RateCard[]

  @@unique([orgId, name], name: "orgId_name")
  @@index([orgId])
  @@map("parties")
}

model Category {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([orgId, name], name: "orgId_name")
  @@index([orgId])
  @@map("categories")
}

model Service {
  id          String  @id @default(cuid())
  code        String
  description String
  parentCode  String?
  categoryId  String

  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  rateCards RateCard[]

  @@unique([code, categoryId], name: "code_categoryId")
  @@index([categoryId])
  @@index([code])
  @@map("services")
}

model RateCard {
  id                 String    @id @default(cuid())
  hospitalId         String
  partyId            String
  serviceId          String
  rate               Decimal   @db.Decimal(12, 2)
  revisedRate        Decimal?  @db.Decimal(12, 2)
  effectiveStartDate DateTime
  effectiveEndDate   DateTime?
  createdById        String
  createdAt          DateTime  @default(now())

  hospital  Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([hospitalId, partyId, serviceId, effectiveStartDate], name: "rate_lookup_idx")
  @@map("rate_cards")
}

// ─── Claim Processing ────────────────────────────────────────────

enum ClaimStatus {
  PENDING_REVIEW
  APPROVED
  FLAGGED
  EXPORTED
}

model ClaimExtraction {
  id               String      @id @default(cuid())
  requestId        String      @unique
  orgId            String
  userId           String
  fileNameHash     String?
  extractedData    Json
  crossCheckResult Json?
  status           ClaimStatus @default(PENDING_REVIEW)
  outputHash       String?
  modelId          String?
  promptVersion    String?
  createdAt        DateTime    @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@map("claim_extractions")
}

// ─── Usage & Cost Tracking ───────────────────────────────────────

enum UsageStatus {
  SUCCESS
  FAILED
}

model OcrUsageLog {
  id               String      @id @default(cuid())
  orgId            String
  userId           String
  requestId        String
  inputTokens      Int
  outputTokens     Int
  totalTokens      Int
  inputCostUsd     Decimal     @db.Decimal(10, 8)
  outputCostUsd    Decimal     @db.Decimal(10, 8)
  totalCostUsd     Decimal     @db.Decimal(10, 8)
  processingTimeMs Int?
  status           UsageStatus @default(SUCCESS)
  createdAt        DateTime    @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@map("ocr_usage_logs")
}

// ─── Audit ───────────────────────────────────────────────────────

enum AuditAction {
  LOGIN
  LOGOUT
  FORCE_LOGOUT
  UPLOAD_CLAIM
  CREATE_USER
  DEACTIVATE_USER
  CREATE_ORG
  SET_QUOTA
  IMPORT_RATES
  EXPORT_CLAIM
  QUOTA_EXCEEDED
}

model AuditLog {
  id           String      @id @default(cuid())
  orgId        String?
  actorUserId  String
  actionType   AuditAction
  targetEntity String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actor User          @relation(fields: [actorUserId], references: [id])

  @@index([orgId])
  @@index([actorUserId])
  @@index([actionType])
  @@index([createdAt])
  @@map("audit_logs")
}
